PORT=5000
HOST=0.0.0.0
CORS_ORIGIN=*
ENABLE_DEV_INSPECTOR=true

DB_SERVER=127.0.0.1
DB_PORT=1433
DB_DATABASE=your_database
DB_USER=your_user
DB_PASSWORD=your_password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_REQUEST_TIMEOUT_MS=120000
STOCK_CACHE_TTL_MS=300000
REQUIRE_SQL_STOCK_CACHE=false
# Optional comma-separated override. If empty, the API treats the highest numeric ST_SIGLA as current.
CURRENT_SEASON_CODES=

BLOB_STORE_ID=store_xxxxxxxxxxxxx
BLOB_READ_WRITE_TOKEN=your_blob_read_write_token
# Optional compatibility with an existing env naming convention
BLOB_PUBLIC_READ_WRITE_TOKEN=

# The root prefix stored in SQL, usually the UNC photo share.
IMAGE_SOURCE_DB_ROOT=\\\\SERVER-ATELIER\\Foto
# The actual path on the machine running the sync.
# Keep it equal to IMAGE_SOURCE_DB_ROOT if the share is mounted directly.
IMAGE_SOURCE_LOCAL_ROOT=\\\\SERVER-ATELIER\\Foto

IMAGE_SYNC_MANIFEST_PATH=./data/image-sync-manifest.json
IMAGE_SYNC_BLOB_PREFIX=catalog
IMAGE_SYNC_BLOB_ACCESS=public
IMAGE_SYNC_CACHE_CONTROL_MAX_AGE=31536000
IMAGE_SYNC_CONCURRENCY=4
IMAGE_SYNC_MANIFEST_CACHE_TTL_MS=5000
